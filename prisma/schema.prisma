// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  auth0Id       String    @unique
  email         String    @unique
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  trips         Trip[]
  favoriteLines Line[]
}

model Trip {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lineId        String
  line          Line      @relation(fields: [lineId], references: [id])
  startStationId  String
  startStation  Station   @relation("TripStartStation", fields: [startStationId], references: [id])
  endStationId  String
  endStation    Station   @relation("TripEndStation", fields: [endStationId], references: [id])
  tripDate      DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Line {
  id            String    @id @default(uuid())
  name          String    @unique
  color         String
  trips         Trip[]
  users         User[] 
  stations      Station[]
}

model Station {
  id            String    @id @default(uuid())
  name          String
  borough       String
  latitude      Float
  longitude     Float
  lines         Line[]
  tripsAsStart  Trip[]    @relation("TripStartStation")
  tripsAsEnd    Trip[]    @relation("TripEndStation")
}